# X Account Configuration
FOLLOW_ACCOUNTS=elonmusk,OpenAI,AndrewYNg

# Email Configuration
EMAIL_TO=user@example.com
EMAIL_FROM=xdigest@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Storage Paths
DB_PATH=~/.xdigest/xdigest.db
LOG_PATH=~/.xdigest/logs/
BROWSER_DATA_PATH=~/.xdigest/browser/

# Scraping Configuration
HEADLESS=true
MAX_POSTS_PER_ACCOUNT=50

# Note: Sensitive credentials (X password, Gemini API key, SMTP password)
# are stored in macOS Keychain via setup_credentials.py
