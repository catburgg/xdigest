# X Account Configuration
# Comma-separated list of X usernames to follow (no @ symbol, no spaces)
FOLLOW_ACCOUNTS=OpenAI,AnthropicAI,xAI,a16z,ycombinator,lightspeedvp,sequoia,jeffdean,lexfridman,gdb,svlevine,demishassabis,reidhoffman,karpathy

# Email Configuration
EMAIL_TO=your-email@gmail.com
EMAIL_FROM=your-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com

# Storage Paths (will be created automatically)
DB_PATH=~/.xdigest/xdigest.db
LOG_PATH=~/.xdigest/logs/
BROWSER_DATA_PATH=~/.xdigest/browser/

# Scraping Configuration
HEADLESS=true
SCROLL_PAUSE=2
MAX_SCROLLS=10
POST_HOURS_WINDOW=12

# Note: Sensitive credentials are stored in macOS Keychain (not in this file)
# Run setup_credentials.py to configure:
#   - X_USERNAME (your X/Twitter username)
#   - X_PASSWORD (your X/Twitter password)
#   - GEMINI_API_KEY (from https://aistudio.google.com/app/apikey)
#   - SMTP_PASSWORD (Gmail App Password from https://myaccount.google.com/apppasswords)
