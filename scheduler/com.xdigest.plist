<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.xdigest</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/miniconda3/envs/xdigest/bin/python</string>
        <string>/Users/catburg/xdigest/main.py</string>
    </array>

    <key>StartCalendarInterval</key>
    <array>
        <!-- 7 AM -->
        <dict>
            <key>Hour</key>
            <integer>7</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <!-- 7 PM -->
        <dict>
            <key>Hour</key>
            <integer>19</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/catburg/Library/Logs/xdigest.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/catburg/Library/Logs/xdigest.error.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/catburg/xdigest</string>

    <key>RunAtLoad</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/miniconda3/envs/xdigest/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
